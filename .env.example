# ===== BASE DE DATOS (Supabase PostgreSQL) =====
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# ===== AUTENTICACIÓN =====
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NEXTAUTH_SECRET="GENERAR-TOKEN-SEGURO-AQUI"
NEXT_PUBLIC_URL="https://teinvitoapp.com.ar"

# ===== ADMIN =====
ADMIN_EMAIL="tu-email@dominio.com"
# Generar hash con: node -e "require('bcryptjs').hash('TU-PASSWORD', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH="$2b$12$HASH-GENERADO-CON-BCRYPT"
# Fallback temporal (eliminar cuando ADMIN_PASSWORD_HASH esté configurado):
ADMIN_PASSWORD="tu-password-temporal"

# ===== MERCADOPAGO =====
MP_ACCESS_TOKEN="APP_USR-tu-access-token-de-produccion"
# Opcional: para verificación de webhooks (panel MP → Webhooks → Secret)
MP_WEBHOOK_SECRET="tu-webhook-secret"
