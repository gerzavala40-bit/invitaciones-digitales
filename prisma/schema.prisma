generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  plan      String   @default("BASICO")
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id           String   @id @default(cuid())
  slug         String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  // Datos del evento
  title        String
  subtitle     String?
  eventType    String   @default("boda")
  eventDate    DateTime
  eventTime    String
  
  // Ubicaciones
  venueName    String
  venueAddress String
  venueLatLng  String?
  ceremonyName    String?
  ceremonyAddress String?
  ceremonyLatLng  String?
  ceremonyTime    String?
  
  // Personalizacion
  templateId   String   @default("elegant-dark")
  primaryColor String   @default("#d4af37")
  musicUrl     String?
  phrase       String?
  dressCode    String?
  hashtag      String?
  
  // Finanzas
  bankAlias    String?
  bankCBU      String?
  bankHolder   String?
  
  // Config
  rsvpEnabled  Boolean  @default(true)
  rsvpDeadline String?
  isActive     Boolean  @default(true)
  
  // Relaciones
  photos       Photo[]
  rsvps        RSVP[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RSVP {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id])
  guestName    String
  guestCount   Int      @default(1)
  dietaryNotes String?
  songRequest  String?
  confirmed    Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Photo {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  url     String
  order   Int    @default(0)
}
